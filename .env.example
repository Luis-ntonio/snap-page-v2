# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and keys from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. NEVER expose to the client. Used by api/notificaciones and api/chatbot.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solo para el CLI de Supabase (npx supabase ...), no lo usa la app en runtime.
# Generar en https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# ─── Site / negocio ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP=51922272439
NEXT_PUBLIC_EMAIL_ADMIN=fotolibros.snap@gmail.com

# Cuando esté listo el auth real (usuarios reales en Supabase), poner en 'true' para que
# proxy.ts proteja /admin y /mi-cuenta. Mientras esté vacío/false, el modo demo sigue funcionando.
ENFORCE_AUTH=false

# ─── Email (opcional) ────────────────────────────────────────────────────────
# Resend API key para el email de notificación de nuevo pedido. Si falta, se omite el envío.
RESEND_API_KEY=

# ─── Chatbot IA (opcional) ───────────────────────────────────────────────────
# OpenAI API key (platform.openai.com/api-keys) para respuestas del chatbot con gpt-4o-mini.
# Si falta, el chatbot cae a matching por keywords. Ver COSTOS_CHATBOT.md para el estimado de costo.
OPENAI_API_KEY=
